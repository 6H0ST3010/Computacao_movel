<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme . -->
    <style name="Theme.CoolWeatherAPP"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color . -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color . -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color . -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here . -->
        <item name="background">@color/viewBG</item>
        <item name="cardBgColor">@color/cardday</item>
        <item name="android:textColor">@color/textday</item>
        <item name ="android:textSize">18sp</item>
        <item name ="android:textStyle">bold</item>
    </style>

    <style name="Theme_Day" parent="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/sunny</item>
        <item name="cardBgColor">@color/cardday</item>
        <item name="android:textColor">@color/textday</item>
    </style>

    <style name="Theme_Day_Land" parent="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/sunny_land</item>
        <item name="cardBgColor">@color/cardday</item>
        <item name="android:textColor">@color/textday</item>
    </style>

    <style name="Theme_Night" parent="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/night</item>
        <item name="cardBgColor">@color/cardnight</item>
        <item name="android:textColor">@color/textnight</item>
    </style>

    <style name="Theme_Night_Land" parent="Theme.CoolWeatherAPP">
        <item name="android:windowBackground">@drawable/night_land</item>
        <item name="cardBgColor">@color/cardnight</item>
        <item name="android:textColor">@color/textnight</item>
    </style>

</resources>